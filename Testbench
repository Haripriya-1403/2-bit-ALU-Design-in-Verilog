module alu_2bit_tb;

reg [1:0] A, B;
reg [2:0] sel;
wire [1:0] result;

alu_2bit uut (
    .A(A),
    .B(B),
    .sel(sel),
    .result(result)
);

initial begin
    $monitor("A=%b B=%b sel=%b result=%b", A, B, sel, result);

    A=2'b01; B=2'b10;

    sel=3'b00; #10;
    sel=3'b01; #10;
    sel=3'b10; #10;
    sel=3'b11; #10;
  

    $finish;
end

endmodule
